{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Example",
  "type": "object",
  "required": ["id", "title", "content"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "source": { "type": "string" },
    "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "estimatedMinutes": { "type": "number" },
    "tags": { "type": "array", "items": { "type": "string" } }
  }
}
