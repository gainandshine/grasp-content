{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Flashcard",
  "type": "object",
  "required": ["id", "cards"],
  "properties": {
    "id": { "type": "string" },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "front", "back"],
        "properties": {
          "id": { "type": "string" },
          "front": { "type": "string" },
          "back": { "type": "string" },
          "hint": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "difficulty": { "type": "string" },
        "estimatedMinutes": { "type": "number" }
      }
    }
  }
}
