{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topic",
  "type": "object",
  "required": ["id", "name", "conceptId"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "conceptId": { "type": "string", "description": "Primary concept ID for this topic" },
    "metadata": {
      "type": "object",
      "properties": {
        "order": { "type": "integer" },
        "estimatedMinutes": { "type": "number" },
        "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] }
      }
    }
  }
}
